<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <PageHeight>11in</PageHeight>
  <PageWidth>8.5in</PageWidth>
  <TopMargin>.5in</TopMargin>
  <LeftMargin>.5in</LeftMargin>
  <RightMargin>.5in</RightMargin>
  <BottomMargin>.5in</BottomMargin>
  <Width>7.5in</Width>

  <ReportParameters>
    <ReportParameter Name="Country">
      <DataType>String</DataType>
      <Nullable>False</Nullable>
      <AllowBlank>False</AllowBlank>
      <DefaultValue>
        <Values>
          <Value>Germany</Value>
        </Values>
      </DefaultValue>
      <Prompt>Country</Prompt>
    </ReportParameter>
  </ReportParameters>

  <DataSources>
    <DataSource Name="DS1">
      <ConnectionProperties>
        <DataProvider>Microsoft.Data.Sqlite</DataProvider>
        <!-- Connection string is overridden at runtime via DataSource.UserConnection -->
        <ConnectString>Data Source=sqlitetestdb2.db</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="Data">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT CustomerID, CompanyName, ContactName, City, Phone FROM Customers WHERE Country = 'Germany' ORDER BY CompanyName</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerID">
          <DataField>CustomerID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CompanyName">
          <DataField>CompanyName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ContactName">
          <DataField>ContactName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="City">
          <DataField>City</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Phone">
          <DataField>Phone</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>

  <PageHeader>
    <Height>.7in</Height>
    <PrintOnFirstPage>true</PrintOnFirstPage>
    <PrintOnLastPage>true</PrintOnLastPage>
    <ReportItems>
      <Textbox Name="Title">
        <Top>.1in</Top>
        <Left>0in</Left>
        <Width>7.5in</Width>
        <Height>.3in</Height>
        <Value>="Customers — " &amp; Parameters!Country.Value</Value>
        <Style>
          <FontSize>16pt</FontSize>
          <FontWeight>Bold</FontWeight>
        </Style>
      </Textbox>
      <Textbox Name="Generated">
        <Top>.45in</Top>
        <Left>0in</Left>
        <Width>7.5in</Width>
        <Height>.12in</Height>
        <Value>=Format(Today(), "MMMM d, yyyy")</Value>
        <Style>
          <FontSize>8pt</FontSize>
          <Color>Gray</Color>
        </Style>
      </Textbox>
    </ReportItems>
  </PageHeader>

  <Body>
    <Height>3in</Height>
    <ReportItems>
      <Table Name="CustomerTable">
        <DataSetName>Data</DataSetName>
        <NoRows>="No customers found in " &amp; Parameters!Country.Value &amp; "."</NoRows>
        <Top>0in</Top>
        <Left>0in</Left>
        <TableColumns>
          <TableColumn><Width>.75in</Width></TableColumn>
          <TableColumn><Width>2in</Width></TableColumn>
          <TableColumn><Width>1.75in</Width></TableColumn>
          <TableColumn><Width>1.25in</Width></TableColumn>
          <TableColumn><Width>1.75in</Width></TableColumn>
        </TableColumns>
        <Header>
          <TableRows>
            <TableRow>
              <Height>16pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="H_ID">
                      <Value>ID</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                        <BackgroundColor>#ED7D31</BackgroundColor>
                        <Color>White</Color>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="H_Company">
                      <Value>Company</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                        <BackgroundColor>#ED7D31</BackgroundColor>
                        <Color>White</Color>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="H_Contact">
                      <Value>Contact</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                        <BackgroundColor>#ED7D31</BackgroundColor>
                        <Color>White</Color>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="H_City">
                      <Value>City</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                        <BackgroundColor>#ED7D31</BackgroundColor>
                        <Color>White</Color>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="H_Phone">
                      <Value>Phone</Value>
                      <Style>
                        <FontWeight>Bold</FontWeight>
                        <BackgroundColor>#ED7D31</BackgroundColor>
                        <Color>White</Color>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
          </TableRows>
          <RepeatOnNewPage>true</RepeatOnNewPage>
        </Header>
        <Details>
          <TableRows>
            <TableRow>
              <Height>14pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="CustomerID">
                      <Value>=Fields!CustomerID.Value</Value>
                      <Style>
                        <BackgroundColor>=IIf(RowNumber(Nothing) Mod 2 = 0, "#FFF2E8", "White")</BackgroundColor>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="CompanyName">
                      <Value>=Fields!CompanyName.Value</Value>
                      <CanGrow>true</CanGrow>
                      <Style>
                        <BackgroundColor>=IIf(RowNumber(Nothing) Mod 2 = 0, "#FFF2E8", "White")</BackgroundColor>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="ContactName">
                      <Value>=Fields!ContactName.Value</Value>
                      <CanGrow>true</CanGrow>
                      <Style>
                        <BackgroundColor>=IIf(RowNumber(Nothing) Mod 2 = 0, "#FFF2E8", "White")</BackgroundColor>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="City">
                      <Value>=Fields!City.Value</Value>
                      <Style>
                        <BackgroundColor>=IIf(RowNumber(Nothing) Mod 2 = 0, "#FFF2E8", "White")</BackgroundColor>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Phone">
                      <Value>=Fields!Phone.Value</Value>
                      <Style>
                        <BackgroundColor>=IIf(RowNumber(Nothing) Mod 2 = 0, "#FFF2E8", "White")</BackgroundColor>
                        <PaddingLeft>4pt</PaddingLeft>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
          </TableRows>
        </Details>
      </Table>
    </ReportItems>
  </Body>

  <PageFooter>
    <Height>18pt</Height>
    <PrintOnFirstPage>true</PrintOnFirstPage>
    <PrintOnLastPage>true</PrintOnLastPage>
    <ReportItems>
      <Textbox Name="PageNum">
        <Top>2pt</Top>
        <Left>0in</Left>
        <Width>3in</Width>
        <Height>14pt</Height>
        <Value>=Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value>
        <Style><FontSize>9pt</FontSize></Style>
      </Textbox>
    </ReportItems>
  </PageFooter>
</Report>
